{
  "Routes": [

    //Service 1 Api
    //Get List Urls
    {
      "DownstreamPathTemplate": "/api/Urls",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7157
        }
      ],
      "UpstreamPathTemplate": "/Urls",
      "UpstreamHttpMethod": [ "Get" ],
      "FileCacheOptions": {
        "TtlSeconds": 15,
        "Region": "default",
        "Header": "ShortenUrl"
      }
    },

    //Get Url by Id
    {
      "DownstreamPathTemplate": "/api/Urls/{id}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Post": 7157
        }
      ],
      "UpstreamPathTemplate": "/Urls/{id}",
      "UpstreamHttpMethod": [ "Get" ]
    },

    //Shorten Url
    {
      "DownstreamPathTemplate": "/api/Urls/shorten",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Post": 7157
        }
      ],
      "UpstreamPathTemplate": "/Urls/shorten",
      "UpstreamHttpMethod": [ "Post" ]
    },

    //Redict Shorten Url
    {
        "DownstreamPathTemplate": "/api/Urls/expand/{shortCode}",
        "DownstreamScheme": "https",
        "DownstreamHostAndPorts": [
            {
                "Host": "localhost",
                "Post": 7157
            }
        ],
        "UpstreamPathTemplate": "/Urlsexpand/{shortCode}",
        "UpstreamHttpMethod": [ "Get" ]
    },

    // Service 2 Api
    // Get Users
    {
      "DownstreamPathTemplate": "/api/Users",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Post": 7163
        }
      ],
      "UpstreamPathTemplate": "/api/Users",
      "UpstreamHttpMethod": [ "Get" ],
      "FileCacheOptions": {
        "TtlSeconds": 15,
        "Region": "default",
        "Header": "User"
      }
    },

    //Get User by Id
    {
      "DownstreamPathTemplate": "/api/Users/{id}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Post": 7163
        }
      ],
      "UpstreamPathTemplate": "/Users",
      "UpstreamHttpMethod": [ "Get" ]
    },

    //Register
    {
      "DownstreamPathTemplate": "/api/Users/Register",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Post": 7157
        }
      ],
      "UpstreamPathTemplate": "/Users",
      "UpstreamHttpMethod": [ "Post" ]
    }

  ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:7136",
        "RateLimitOptions": {
            "QuotaExceededMessage": "You are overwhelming me with multiple requests. Relax small"
        }
    }
}
